// Yeh JSON key preview ki value define kar rahi hai.
  },
// Yeh JSON structure ke block ko open ya close kar rahi hai.
  "dependencies": {
// Yeh JSON key dependencies ki value define kar rahi hai.
    "@tailwindcss/vite": "^4.1.17",
// Yeh JSON key @tailwindcss/vite ki value define kar rahi hai.
    "framer-motion": "^12.23.25",
// Yeh JSON key framer-motion ki value define kar rahi hai.
    "react": "^19.2.0",
// Yeh JSON key react ki value define kar rahi hai.
